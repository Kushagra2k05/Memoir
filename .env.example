# Firebase client config for Vite app
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Admin credentials for server-side API
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-admin-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_SERVICE_ACCOUNT={}

# AI service keys (Gemini for story generation, Stability.ai for illustrations)
VITE_GEMINI_API_KEY=your-google-generative-ai-api-key
STABILITY_API_KEY=your-stability-api-key

# API server port
PORT=5175
